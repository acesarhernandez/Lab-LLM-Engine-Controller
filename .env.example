ENGINE_API_KEY=replace-with-a-long-random-string

ENGINE_HOST=0.0.0.0
ENGINE_PORT=8088
ENGINE_LABEL=Gaming PC

# If empty, the service falls back to the host from ENGINE_OLLAMA_BASE_URL.
ENGINE_PC_HOST=
ENGINE_PC_PROBE_PORT=3389

ENGINE_OLLAMA_BASE_URL=http://192.168.1.50:11434
ENGINE_OLLAMA_READY_PATH=/api/tags

ENGINE_WOL_ENABLED=true
ENGINE_WOL_MAC=AA:BB:CC:DD:EE:FF
ENGINE_WOL_BROADCAST_IP=255.255.255.255
ENGINE_WOL_PORT=9

ENGINE_WAKE_COOLDOWN_SECONDS=20
# Keep "waking" status stable while the PC boots even after cooldown ends.
ENGINE_WAKE_GRACE_SECONDS=90
ENGINE_READY_TIMEOUT_SECONDS=90
ENGINE_STATUS_CACHE_SECONDS_READY=10
ENGINE_STATUS_CACHE_SECONDS_WAKING=3
ENGINE_STATUS_CACHE_SECONDS_OFFLINE=5
